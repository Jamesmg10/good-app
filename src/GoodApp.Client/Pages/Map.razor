@page "/map"

@using System.Globalization
@using System.Text.Json

<PageTitle>Good — Map</PageTitle>

<h1 class="map-page-title">Charitable opportunities near you</h1>

<div class="map-page">
    <div class="map-body">
        <div class="map-drawer-stack @(_drawerOpen ? "map-drawer-stack--open" : null)">
            <button type="button"
                    class="map-drawer-pin"
                    aria-expanded="@_drawerOpen"
                    aria-controls="map-giving-drawer"
                    title="@(_drawerOpen ? "Collapse giving menu" : "Open giving menu")"
                    @onclick="ToggleDrawerAsync">
                <span class="map-drawer-pin__icon" aria-hidden="true">@(_drawerOpen ? "⟨" : "⟩")</span>
                <span class="map-drawer-pin__label">My giving</span>
            </button>
            <aside id="map-giving-drawer" class="map-drawer-panel" aria-hidden="@(!_drawerOpen)">
                <div class="map-drawer-panel__inner">
                    <h2 class="map-drawer-panel__heading">Giving</h2>
                    <p class="map-drawer-panel__lede">Pins on the map are volunteer, donation, and event opportunities from the API.</p>

                    <details class="map-blade" open>
                        <summary class="map-blade__summary">My contributions</summary>
                        <div class="map-blade__body">
                            <p class="map-blade__muted">Linked donations and volunteer hours will show here when backend giving data is connected.</p>
                            <ul class="map-blade__list">
                                <li><span class="map-blade__stat">—</span> lifetime given (placeholder)</li>
                                <li><span class="map-blade__stat">—</span> hours volunteered (placeholder)</li>
                            </ul>
                        </div>
                    </details>

                    <details class="map-blade">
                        <summary class="map-blade__summary">Saved opportunities</summary>
                        <div class="map-blade__body">
                            <p class="map-blade__muted">Save pins to revisit later—coming soon.</p>
                        </div>
                    </details>
                </div>
            </aside>
        </div>

        <div class="map-canvas-wrap">
            <div class="map-top-stack">
                <div class="map-search-shell" role="search">
                    <label class="map-search-shell__label" for="map-area-search">Search by area</label>
                    <div class="map-search-shell__field">
                        <span class="map-search-shell__icon" aria-hidden="true">⌕</span>
                        <input id="map-area-search"
                               class="map-search-shell__input"
                               type="search"
                               autocomplete="off"
                               placeholder="City, neighborhood, or address…"
                               @bind="_searchQuery"
                               @bind:event="oninput"
                               @onkeydown="OnSearchKeyDownAsync"
                               disabled="@(!_mapsReady || _searchBusy)" />
                        <button type="button"
                                class="map-search-shell__btn"
                                disabled="@(!_mapsReady || _searchBusy)"
                                @onclick="SearchAreaAsync">
                            @if (_searchBusy)
                            {
                                <span>Searching…</span>
                            }
                            else
                            {
                                <span>Search</span>
                            }
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(_searchFeedback))
                    {
                        <p class="map-search-shell__feedback" role="status">@_searchFeedback</p>
                    }
                </div>

                @if (_showLocationPrompt && _mapsReady && string.IsNullOrEmpty(_error))
                {
                    <div class="map-location-prompt" role="region" aria-label="Share location">
                        <p class="map-location-prompt__text">
                            Share your location once to prioritize opportunities around you. You can change this anytime in the browser settings.
                        </p>
                        <div class="map-location-prompt__actions">
                            <button type="button"
                                    class="map-location-prompt__primary"
                                    disabled="@_locationBusy"
                                    @onclick="ShareLocationAsync">
                                @if (_locationBusy)
                                {
                                    <span>Locating…</span>
                                }
                                else
                                {
                                    <span>Share location</span>
                                }
                            </button>
                            <button type="button"
                                    class="map-location-prompt__secondary"
                                    disabled="@_locationBusy"
                                    @onclick="DismissLocationPromptAsync">
                                Not now
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_locationPromptNote))
                        {
                            <p class="map-location-prompt__error" role="alert">@_locationPromptNote</p>
                        }
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="map-overlay-alert alert" role="alert">@_error</div>
            }

            <div class="map-legend map-legend--floating" aria-label="Marker legend">
                <span class="map-legend__title">Legend</span>
                <span class="map-legend__item"><span class="map-legend__swatch map-legend__swatch--volunteer">V</span> Volunteer</span>
                <span class="map-legend__item"><span class="map-legend__swatch map-legend__swatch--donation">D</span> Donation</span>
                <span class="map-legend__item"><span class="map-legend__swatch map-legend__swatch--event">E</span> Event</span>
            </div>

            <div id="good-map" class="good-map @(_loading ? "loading" : "")"></div>

            @if (_loading && string.IsNullOrEmpty(_error))
            {
                <p class="map-loading-label">Loading map…</p>
            }
        </div>
    </div>
</div>

@code {
    private const string MapContainerId = "good-map";
    private const string PlaceholderMapsKey = "YOUR_AZURE_MAPS_PRIMARY_KEY";
    private const string LocationPromptSessionKey = "goodapp.map.locationPrompt";
    private const double BboxHalfDegrees = 0.12;

    private static readonly JsonSerializerOptions JsonOptions = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    };

    private static bool IsPlaceholderMapsKey(string key) =>
        string.Equals(key.Trim(), PlaceholderMapsKey, StringComparison.OrdinalIgnoreCase);

    [Inject]
    private HttpClient Http { get; set; } = default!;

    [Inject]
    private IJSRuntime Js { get; set; } = default!;

    [Inject]
    private AuthenticationStateProvider AuthenticationStateProvider { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private IJSObjectReference? _mapModule;
    private string? _error;
    private bool _loading = true;
    private bool _isAuthenticated;
    private bool _drawerOpen = false;
    private bool _mapsReady;
    private string _searchQuery = "";
    private bool _searchBusy;
    private string? _searchFeedback;
    private bool _showLocationPrompt;
    private bool _locationBusy;
    private string? _locationPromptNote;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = state.User.Identity?.IsAuthenticated == true;
        if (!_isAuthenticated)
            Navigation.NavigateTo("/login");
    }

    private async Task ToggleDrawerAsync()
    {
        _drawerOpen = !_drawerOpen;
        StateHasChanged();
        await Task.Delay(320);
        await TryResizeMapAsync();
    }

    private async Task TryResizeMapAsync()
    {
        if (_mapModule is null)
            return;
        try
        {
            await _mapModule.InvokeVoidAsync("resizeMap");
        }
        catch
        {
            /* map may not be ready */
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !_isAuthenticated)
            return;

        try
        {
            await InitMapAndDataAsync();
        }
        catch (HttpRequestException ex)
        {
            _error = $"Cannot reach the API ({Http.BaseAddress}). Start the API: cd src/GoodApp.Api && dotnet run — {ex.Message}";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task InitMapAndDataAsync()
    {
        var auth = await Http.GetFromJsonAsync<MapAuthResponse>("api/maps/auth");
        if (auth is null || !string.IsNullOrEmpty(auth.Error) || string.IsNullOrEmpty(auth.SubscriptionKey))
        {
            _error = auth?.Error ?? "Could not load map authentication. Set AzureMaps:SubscriptionKey on the API (see README).";
            return;
        }

        if (IsPlaceholderMapsKey(auth.SubscriptionKey))
        {
            _error = "Azure Maps key is still the placeholder. In src/GoodApp.Api run: dotnet user-secrets set \"AzureMaps:SubscriptionKey\" \"<your real Primary Key from Azure Portal>\"";
            return;
        }

        _mapModule = await Js.InvokeAsync<IJSObjectReference>("import", "./js/azureMaps.js");
        await _mapModule.InvokeVoidAsync("initMap", MapContainerId, auth.SubscriptionKey);

        var opportunities = await Http.GetFromJsonAsync<List<OpportunityDto>>("api/opportunities") ?? [];
        var json = JsonSerializer.Serialize(opportunities, JsonOptions);
        await _mapModule.InvokeVoidAsync("loadOpportunities", json, null);

        var dismissed = await Js.InvokeAsync<string?>("goodAppInterop.sessionGet", LocationPromptSessionKey);
        _showLocationPrompt = dismissed is null;

        _mapsReady = true;
        await TryResizeMapAsync();
    }

    private static string OpportunitiesInAreaUrl(double lat, double lon)
    {
        double minLat = lat - BboxHalfDegrees;
        double maxLat = lat + BboxHalfDegrees;
        double minLon = lon - BboxHalfDegrees;
        double maxLon = lon + BboxHalfDegrees;
        return
            "api/opportunities?minLat=" + minLat.ToString(CultureInfo.InvariantCulture)
            + "&minLon=" + minLon.ToString(CultureInfo.InvariantCulture)
            + "&maxLat=" + maxLat.ToString(CultureInfo.InvariantCulture)
            + "&maxLon=" + maxLon.ToString(CultureInfo.InvariantCulture);
    }

    private async Task LoadOpportunitiesNearAsync(double lat, double lon)
    {
        if (_mapModule is null)
            return;

        var url = OpportunitiesInAreaUrl(lat, lon);
        var opportunities = await Http.GetFromJsonAsync<List<OpportunityDto>>(url) ?? [];
        var json = JsonSerializer.Serialize(opportunities, JsonOptions);
        await _mapModule.InvokeVoidAsync("loadOpportunities", json, new { center = new { lat, lon }, zoom = 12 });
        _searchFeedback = opportunities.Count == 0
            ? "No listings in this map area yet — try zooming out or searching another neighborhood."
            : $"{opportunities.Count} opportunit{(opportunities.Count == 1 ? "y" : "ies")} in this area.";
    }

    private async Task SearchAreaAsync()
    {
        if (_mapModule is null || string.IsNullOrWhiteSpace(_searchQuery))
            return;

        _searchBusy = true;
        _searchFeedback = null;
        _error = null;
        StateHasChanged();

        try
        {
            var place = await _mapModule.InvokeAsync<GeoCoords>("geocodeAddress", _searchQuery.Trim());
            await LoadOpportunitiesNearAsync(place.Lat, place.Lon);
        }
        catch (JSException ex)
        {
            _searchFeedback = ex.Message;
        }
        catch (Exception ex)
        {
            _searchFeedback = ex.Message;
        }
        finally
        {
            _searchBusy = false;
            StateHasChanged();
            await TryResizeMapAsync();
        }
    }

    private async Task OnSearchKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key != "Enter")
            return;
        await SearchAreaAsync();
    }

    private async Task ShareLocationAsync()
    {
        if (_mapModule is null)
            return;

        _locationBusy = true;
        _locationPromptNote = null;
        StateHasChanged();

        try
        {
            var loc = await _mapModule.InvokeAsync<GeoCoords>("getUserLocation");
            await Js.InvokeVoidAsync("goodAppInterop.sessionSet", LocationPromptSessionKey, "done");
            _showLocationPrompt = false;
            await LoadOpportunitiesNearAsync(loc.Lat, loc.Lon);
        }
        catch (JSException ex)
        {
            _locationPromptNote = ex.Message;
        }
        catch (Exception ex)
        {
            _locationPromptNote = ex.Message;
        }
        finally
        {
            _locationBusy = false;
            StateHasChanged();
            await TryResizeMapAsync();
        }
    }

    private async Task DismissLocationPromptAsync()
    {
        await Js.InvokeVoidAsync("goodAppInterop.sessionSet", LocationPromptSessionKey, "skipped");

        _showLocationPrompt = false;
        _locationPromptNote = null;
        StateHasChanged();
    }

    private sealed class GeoCoords
    {
        public double Lat { get; set; }
        public double Lon { get; set; }
        public string? Label { get; set; }
    }
}
