@page "/map"

<PageTitle>Good — Map</PageTitle>

<h1 class="map-page-title">Charitable opportunities near you</h1>

<div class="map-page">
    <div class="map-body">
        <div class="map-drawer-stack @(_drawerOpen ? "map-drawer-stack--open" : null)">
            <button type="button"
                    class="map-drawer-pin"
                    aria-expanded="@_drawerOpen"
                    aria-controls="map-giving-drawer"
                    title="@(_drawerOpen ? "Collapse giving menu" : "Open giving menu")"
                    @onclick="ToggleDrawerAsync">
                <span class="map-drawer-pin__icon" aria-hidden="true">@(_drawerOpen ? "⟨" : "⟩")</span>
                <span class="map-drawer-pin__label">My giving</span>
            </button>
            <aside id="map-giving-drawer" class="map-drawer-panel" aria-hidden="@(!_drawerOpen)">
                <div class="map-drawer-panel__inner">
                    <h2 class="map-drawer-panel__heading">Giving</h2>
                    <p class="map-drawer-panel__lede">Pins on the map are volunteer, donation, and event opportunities from the API.</p>

                    <details class="map-blade" open>
                        <summary class="map-blade__summary">My contributions</summary>
                        <div class="map-blade__body">
                            <p class="map-blade__muted">Linked donations and volunteer hours will show here when backend giving data is connected.</p>
                            <ul class="map-blade__list">
                                <li><span class="map-blade__stat">—</span> lifetime given (placeholder)</li>
                                <li><span class="map-blade__stat">—</span> hours volunteered (placeholder)</li>
                            </ul>
                        </div>
                    </details>

                    <details class="map-blade">
                        <summary class="map-blade__summary">Saved opportunities</summary>
                        <div class="map-blade__body">
                            <p class="map-blade__muted">Save pins to revisit later—coming soon.</p>
                        </div>
                    </details>
                </div>
            </aside>
        </div>

        <div class="map-canvas-wrap">
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="map-overlay-alert alert" role="alert">@_error</div>
            }

            <div class="map-legend map-legend--floating" aria-label="Marker legend">
                <span class="map-legend__title">Legend</span>
                <span class="map-legend__item"><span class="map-legend__swatch map-legend__swatch--volunteer">V</span> Volunteer</span>
                <span class="map-legend__item"><span class="map-legend__swatch map-legend__swatch--donation">D</span> Donation</span>
                <span class="map-legend__item"><span class="map-legend__swatch map-legend__swatch--event">E</span> Event</span>
            </div>

            <div id="good-map" class="good-map @(_loading ? "loading" : "")"></div>

            @if (_loading && string.IsNullOrEmpty(_error))
            {
                <p class="map-loading-label">Loading map…</p>
            }
        </div>
    </div>
</div>

@code {
    private const string MapContainerId = "good-map";
    private const string PlaceholderMapsKey = "YOUR_AZURE_MAPS_PRIMARY_KEY";

    private static bool IsPlaceholderMapsKey(string key) =>
        string.Equals(key.Trim(), PlaceholderMapsKey, StringComparison.OrdinalIgnoreCase);

    [Inject]
    private HttpClient Http { get; set; } = default!;

    [Inject]
    private IJSRuntime Js { get; set; } = default!;

    [Inject]
    private AuthenticationStateProvider AuthenticationStateProvider { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private IJSObjectReference? _mapModule;
    private string? _error;
    private bool _loading = true;
    private bool _isAuthenticated;
    private bool _drawerOpen = false;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        _isAuthenticated = state.User.Identity?.IsAuthenticated == true;
        if (!_isAuthenticated)
            Navigation.NavigateTo("/login");
    }

    private async Task ToggleDrawerAsync()
    {
        _drawerOpen = !_drawerOpen;
        StateHasChanged();
        await Task.Delay(320);
        await TryResizeMapAsync();
    }

    private async Task TryResizeMapAsync()
    {
        if (_mapModule is null)
            return;
        try
        {
            await _mapModule.InvokeVoidAsync("resizeMap");
        }
        catch
        {
            /* map may not be ready */
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !_isAuthenticated)
            return;

        try
        {
            var auth = await Http.GetFromJsonAsync<MapAuthResponse>("api/maps/auth");
            if (auth is null || !string.IsNullOrEmpty(auth.Error) || string.IsNullOrEmpty(auth.SubscriptionKey))
            {
                _error = auth?.Error ?? "Could not load map authentication. Set AzureMaps:SubscriptionKey on the API (see README).";
                _loading = false;
                StateHasChanged();
                return;
            }

            if (IsPlaceholderMapsKey(auth.SubscriptionKey))
            {
                _error = "Azure Maps key is still the placeholder. In src/GoodApp.Api run: dotnet user-secrets set \"AzureMaps:SubscriptionKey\" \"<your real Primary Key from Azure Portal>\"";
                _loading = false;
                StateHasChanged();
                return;
            }

            _mapModule = await Js.InvokeAsync<IJSObjectReference>("import", "./js/azureMaps.js");
            await _mapModule.InvokeVoidAsync("initMap", MapContainerId, auth.SubscriptionKey);

            var opportunities = await Http.GetFromJsonAsync<List<OpportunityDto>>("api/opportunities") ?? [];
            var json = System.Text.Json.JsonSerializer.Serialize(
                opportunities,
                new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });
            await _mapModule.InvokeVoidAsync("loadOpportunities", json);
            await TryResizeMapAsync();
        }
        catch (HttpRequestException ex)
        {
            _error = $"Cannot reach the API ({Http.BaseAddress}). Start the API: cd src/GoodApp.Api && dotnet run — {ex.Message}";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
}
